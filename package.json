{
  "name": "cube-prep",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --cwd apps/api dev",
    "dev:web": "bun --cwd apps/web dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mts,cts,json,md,mdx,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mts,cts,json,md,mdx,yml,yaml}\""
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
