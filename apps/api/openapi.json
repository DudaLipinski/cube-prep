{
  "openapi": "3.0.0",
  "info": {
    "title": "Cubby API",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "Portion": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "carb",
              "protein",
              "vegetable",
              "legume",
              "broth",
              "sauce",
              "soup",
              "other"
            ]
          },
          "quantity": {
            "type": "number"
          },
          "prepared_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "type",
          "quantity",
          "prepared_at",
          "created_at"
        ]
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "enum": [
              "validation_error"
            ]
          },
          "message": {
            "type": "string"
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              },
              "required": [
                "field",
                "message"
              ]
            }
          }
        },
        "required": [
          "error",
          "message",
          "issues"
        ]
      },
      "NotFoundError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "enum": [
              "not_found"
            ]
          },
          "message": {
            "type": "string"
          },
          "status": {
            "type": "number",
            "enum": [
              404
            ]
          }
        },
        "required": [
          "error",
          "message",
          "status"
        ]
      },
      "CreatePortionBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "example": "Rice cubes"
          },
          "type": {
            "type": "string",
            "enum": [
              "carb",
              "protein",
              "vegetable",
              "legume",
              "broth",
              "sauce",
              "soup",
              "other"
            ]
          },
          "quantity": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true,
            "example": 4
          },
          "prepared_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "name",
          "type",
          "quantity",
          "prepared_at"
        ]
      },
      "UpdatePortionBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "example": "Rice cubes"
          },
          "type": {
            "type": "string",
            "enum": [
              "carb",
              "protein",
              "vegetable",
              "legume",
              "broth",
              "sauce",
              "soup",
              "other"
            ]
          },
          "quantity": {
            "type": "number",
            "minimum": 0,
            "exclusiveMinimum": true,
            "example": 4
          },
          "prepared_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DeletePortionSuccess": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "enum": [
              "Portion deleted successfully"
            ]
          }
        },
        "required": [
          "message"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/portions": {
      "get": {
        "tags": [
          "Portion"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "carb",
                "protein",
                "vegetable",
                "legume",
                "broth",
                "sauce",
                "soup",
                "other"
              ],
              "example": "protein"
            },
            "required": false,
            "name": "type",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "name",
                "quantity",
                "prepared_at",
                "created_at"
              ],
              "example": "created_at"
            },
            "required": false,
            "name": "sort",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "example": "desc"
            },
            "required": false,
            "name": "order",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List portions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Portion"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Portion"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePortionBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created portion",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Portion"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/portions/{id}": {
      "get": {
        "tags": [
          "Portion"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "00000000-0000-0000-0000-000000000001"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Get portion by ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Portion"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "404": {
            "description": "Portion not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Portion"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "00000000-0000-0000-0000-000000000001"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePortionBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated portion",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Portion"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "404": {
            "description": "Portion not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Portion"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "00000000-0000-0000-0000-000000000001"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted portion",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeletePortionSuccess"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "404": {
            "description": "Portion not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      }
    }
  }
}
